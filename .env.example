# Copy this file to `.env` and fill in real values. NEVER commit the real .env.

# --- Database (required) ---
# A PostgreSQL connection string. Use a managed database in production.
DATABASE_URL="postgresql://user:password@host:5432/dbname"

# --- Auth (required) ---
# Signing key for session JWTs. Generate a fresh one: openssl rand -base64 48
# Rotating this logs everyone out.
JWT_SECRET="change-me-generate-with-openssl-rand-base64-48"

# --- App URL (used in outgoing emails; required for correct email links) ---
# Set to your real domain in production, e.g. https://lms.yourcompany.com
APP_URL="http://localhost:3000"

# --- Email / SMTP (optional) ---
# If unset, the app still works — credential emails are simply skipped and the
# admin copies passwords manually. For Gmail, SMTP_PASS is an App Password
# (https://myaccount.google.com/apppasswords), not your account password.
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="465"
SMTP_USER="you@gmail.com"
SMTP_PASS="your-16-char-app-password"
SMTP_FROM="Iceberg <you@gmail.com>"
